<!DOCTYPE html>
<html>
  <head>
    <title>Zaiko Image — Painel de Revisão</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      h1, h2, h3, h4, .font-heading {
        font-family: 'Outfit', sans-serif;
      }
    </style>
  </head>

  <body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-primary border-b border-primary/20 text-white shadow-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-secondary flex items-center justify-center font-bold text-white shadow-inner font-heading text-lg">
            Z
          </div>
          <div>
            <h1 class="text-xl font-bold tracking-tight leading-tight">Zaiko Image</h1>
            <p class="text-xs text-secondary font-medium tracking-wide">PAINEL DE REVISÃO</p>
          </div>
        </div>
        
        <nav class="flex items-center gap-4">
          <% if user_signed_in? %>
            <span class="text-sm text-slate-300">Olá, <strong class="text-white"><%= current_user.email %></strong></span>
            <%= link_to "Fila de Pedidos", root_path, class: "text-sm font-medium hover:text-secondary transition-colors" %>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "text-sm bg-red-600/20 text-red-300 hover:bg-red-600/30 hover:text-white px-3.5 py-1.5 rounded-lg border border-red-500/20 font-medium transition-all cursor-pointer" %>
          <% else %>
            <span class="text-sm text-slate-300">Entre na sua conta</span>
          <% end %>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col">
      <!-- Flash Messages -->
      <% if notice.present? || alert.present? %>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4 w-full">
          <% if notice.present? %>
            <div class="bg-emerald-50 border-l-4 border-emerald-500 text-emerald-800 p-4 rounded-r-lg shadow-sm flex items-center justify-between mb-2">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-sm font-medium"><%= notice %></p>
              </div>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="bg-rose-50 border-l-4 border-rose-500 text-rose-800 p-4 rounded-r-lg shadow-sm flex items-center justify-between mb-2">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-rose-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <p class="text-sm font-medium"><%= alert %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 border-t border-slate-800 text-slate-400 py-6 text-center text-xs">
      <p>&copy; <%= Time.current.year %> Zaiko Image — Painel de Revisão Humana. Todos os direitos reservados.</p>
    </footer>
  </body>
</html>
