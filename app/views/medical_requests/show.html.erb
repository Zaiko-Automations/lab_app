<%
  ai_patient = @ai_data[:paciente] || {}
  ai_solicitante = @ai_data[:solicitante] || {}
  is_readonly = @medical_request.validated?
%>

<div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full flex-grow flex flex-col">
  <!-- Header / Navigation -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between border-b border-slate-200 pb-4 mb-6 gap-4">
    <div>
      <div class="flex items-center gap-2 text-xs font-semibold text-slate-500 uppercase tracking-wider">
        <%= link_to "Fila de Pedidos", root_path, class: "hover:text-primary transition-colors" %>
        <span>/</span>
        <span class="text-slate-800">Pedido #<%= @medical_request.id %></span>
      </div>
      
      <div class="flex items-center gap-3 mt-1">
        <h2 class="text-2xl font-bold text-slate-900 font-heading">Revisão Humana de Dados</h2>
        <% if @medical_request.pending? %>
          <span class="px-2.5 py-1 text-xs font-bold rounded-full bg-amber-100 text-amber-800 border border-amber-200">Aguardando Validação</span>
        <% else %>
          <span class="px-2.5 py-1 text-xs font-bold rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200">Validado</span>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= link_to root_path, class: "px-4 py-2 bg-white hover:bg-slate-50 text-slate-700 text-sm font-semibold rounded-xl border border-slate-300 transition-colors shadow-sm cursor-pointer" do %>
        Voltar para a Fila
      <% end %>
    </div>
  </div>

  <% if is_readonly %>
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 p-4 rounded-xl shadow-sm mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <p class="font-bold">Este pedido já foi validado!</p>
          <p class="text-sm text-emerald-700">Revisado por <strong><%= @medical_request.validated_by&.email %></strong> em <%= @medical_request.validated_at&.strftime("%d/%m/%Y às %H:%M") %>.</p>
        </div>
      </div>
      <div class="text-xs font-mono bg-emerald-100 text-emerald-800 px-3 py-1.5 rounded-lg">
        Conexão: <%= @medical_request.conversation_id %>
      </div>
    </div>
  <% end %>

  <!-- Main Container: Side-by-Side -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start flex-grow">
    
    <!-- LEFT PANEL: Image Viewer (lg:col-span-6) -->
    <div class="lg:col-span-6 flex flex-col gap-4 sticky top-24">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4">
        <h3 class="text-sm font-bold text-slate-800 font-heading mb-3 uppercase tracking-wide">Documentos Recebidos</h3>
        
        <!-- Image Selector Tabs -->
        <div class="flex border-b border-slate-100 pb-3 gap-2" id="doc-tabs">
          <button type="button" onclick="selectImage('pedido_medico')" id="tab-pedido_medico"
                  class="flex-1 text-center py-2 px-3 text-xs font-semibold rounded-lg border transition-all cursor-pointer">
            Pedido Médico
            <% if @medical_request.pedido_medico.attached? %>
              <span class="block text-[9px] text-emerald-500 font-normal">Anexo ok</span>
            <% else %>
              <span class="block text-[9px] text-slate-400 font-normal">Não enviado</span>
            <% end %>
          </button>
          
          <button type="button" onclick="selectImage('documento')" id="tab-documento"
                  class="flex-1 text-center py-2 px-3 text-xs font-semibold rounded-lg border transition-all cursor-pointer">
            RG / CNH
            <% if @medical_request.documento.attached? %>
              <span class="block text-[9px] text-emerald-500 font-normal">Anexo ok</span>
            <% else %>
              <span class="block text-[9px] text-slate-400 font-normal">Não enviado</span>
            <% end %>
          </button>
          
          <button type="button" onclick="selectImage('carteira_convenio')" id="tab-carteira_convenio"
                  class="flex-1 text-center py-2 px-3 text-xs font-semibold rounded-lg border transition-all cursor-pointer">
            Carteirinha
            <% if @medical_request.carteira_convenio.attached? %>
              <span class="block text-[9px] text-emerald-500 font-normal">Anexo ok</span>
            <% else %>
              <span class="block text-[9px] text-slate-400 font-normal">Não enviado</span>
            <% end %>
          </button>
        </div>

        <!-- Viewer Area -->
        <div class="mt-4 bg-slate-900 border border-slate-800 rounded-xl overflow-hidden h-[800px] flex items-center justify-center group relative" id="viewer-container">
          <!-- Image Zoom Container -->
          <div id="image-zoom-box" class="origin-center transition-all cursor-grab active:cursor-grabbing w-full h-full flex items-center justify-center relative" style="transform: scale(1.6) translate(0px, 0px);">
            <!-- Drawing Canvas Overlay -->
            <canvas id="drawing-canvas" class="absolute top-0 left-0 w-full h-full pointer-events-none z-10 hidden"></canvas>

            <!-- Dynamic Images / PDFs -->
            <% if @medical_request.pedido_medico.attached? %>
              <% if @medical_request.pedido_medico.content_type == 'application/pdf' %>
                <iframe id="img-pedido_medico" src="<%= url_for(@medical_request.pedido_medico) %>" class="w-full h-full hidden border-none bg-white relative z-0"></iframe>
              <% else %>
                <img id="img-pedido_medico" src="<%= url_for(@medical_request.pedido_medico) %>" class="max-h-[780px] max-w-full object-contain pointer-events-none select-none hidden relative z-0">
              <% end %>
            <% else %>
              <div id="img-pedido_medico" class="text-slate-500 text-sm hidden p-6 text-center">
                <svg class="w-12 h-12 mx-auto mb-2 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                Nenhum Pedido Médico anexado pela IA.
              </div>
            <% end %>

            <% if @medical_request.documento.attached? %>
              <% if @medical_request.documento.content_type == 'application/pdf' %>
                <iframe id="img-documento" src="<%= url_for(@medical_request.documento) %>" class="w-full h-full hidden border-none bg-white relative z-0"></iframe>
              <% else %>
                <img id="img-documento" src="<%= url_for(@medical_request.documento) %>" class="max-h-[780px] max-w-full object-contain pointer-events-none select-none hidden relative z-0">
              <% end %>
            <% else %>
              <div id="img-documento" class="text-slate-500 text-sm hidden p-6 text-center">
                <svg class="w-12 h-12 mx-auto mb-2 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                Nenhum Documento anexado pela IA.
              </div>
            <% end %>

            <% if @medical_request.carteira_convenio.attached? %>
              <% if @medical_request.carteira_convenio.content_type == 'application/pdf' %>
                <iframe id="img-carteira_convenio" src="<%= url_for(@medical_request.carteira_convenio) %>" class="w-full h-full hidden border-none bg-white relative z-0"></iframe>
              <% else %>
                <img id="img-carteira_convenio" src="<%= url_for(@medical_request.carteira_convenio) %>" class="max-h-[780px] max-w-full object-contain pointer-events-none select-none hidden relative z-0">
              <% end %>
            <% else %>
              <div id="img-carteira_convenio" class="text-slate-500 text-sm hidden p-6 text-center">
                <svg class="w-12 h-12 mx-auto mb-2 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                Nenhuma Carteirinha anexada pela IA.
              </div>
            <% end %>
          </div>
        </div>

        <!-- UI Controls (Moved below the image) -->
        <div class="mt-3 flex flex-wrap gap-2 items-center justify-between">
          <!-- Drawing Toolbar -->
          <div id="draw-toolbar" class="flex bg-slate-800 text-white rounded-lg p-1 border border-slate-700 shadow-sm gap-1 items-center">
            <button type="button" onclick="toggleDrawMode()" id="btn-draw" class="w-8 h-8 rounded hover:bg-slate-700 transition-all text-sm flex items-center justify-center cursor-pointer" title="Modo Anotação">🖍️</button>
            <div class="w-px h-5 bg-slate-600 mx-1"></div>
            <button type="button" onclick="setDrawColor('#ff0000')" class="w-5 h-5 rounded-full bg-red-500 ring-2 ring-transparent ring-offset-1 ring-offset-slate-800 hover:scale-110 cursor-pointer transition-all draw-color" title="Vermelho"></button>
            <button type="button" onclick="setDrawColor('#00ff00')" class="w-5 h-5 rounded-full bg-green-500 ring-2 ring-transparent ring-offset-1 ring-offset-slate-800 hover:scale-110 cursor-pointer transition-all draw-color" title="Verde"></button>
            <button type="button" onclick="setDrawColor('#0088ff')" class="w-5 h-5 rounded-full bg-blue-500 ring-2 ring-transparent ring-offset-1 ring-offset-slate-800 hover:scale-110 cursor-pointer transition-all draw-color" title="Azul"></button>
            <button type="button" onclick="setDrawColor('#ffff00')" class="w-5 h-5 rounded-full bg-yellow-400 ring-2 ring-transparent ring-offset-1 ring-offset-slate-800 hover:scale-110 cursor-pointer transition-all draw-color" title="Amarelo"></button>
            <button type="button" onclick="setDrawColor('#ffffff')" class="w-5 h-5 rounded-full bg-white ring-2 ring-transparent ring-offset-1 ring-offset-slate-800 hover:scale-110 cursor-pointer transition-all draw-color ring-slate-400" title="Branco"></button>
            <div class="w-px h-5 bg-slate-600 mx-1"></div>
            <button type="button" onclick="clearDraw()" class="px-2 h-8 rounded hover:bg-slate-700 font-semibold transition-all text-xs flex items-center justify-center cursor-pointer" title="Apagar Desenhos">Limpar</button>
          </div>

          <!-- Zoom Toolbar -->
          <div class="flex bg-slate-800 text-white rounded-lg p-1 border border-slate-700 shadow-sm gap-1">
            <button type="button" onclick="adjustZoom(0.2)" class="w-8 h-8 rounded hover:bg-slate-700 font-bold transition-all text-sm flex items-center justify-center cursor-pointer" title="Aumentar Zoom">+</button>
            <button type="button" onclick="adjustZoom(-0.2)" class="w-8 h-8 rounded hover:bg-slate-700 font-bold transition-all text-sm flex items-center justify-center cursor-pointer" title="Diminuir Zoom">-</button>
            <button type="button" onclick="resetViewer()" class="px-2 h-8 rounded hover:bg-slate-700 font-semibold transition-all text-xs flex items-center justify-center cursor-pointer" title="Redefinir">Recentralizar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT PANEL: Verification Form (lg:col-span-6) -->
    <div class="lg:col-span-6">
      <%= form_for(@medical_request, url: validate_medical_request_path(@medical_request), method: :post, html: { id: "validation-form", class: "bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden" }) do |f| %>
        
        <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
          <div>
            <h3 class="text-base font-bold text-primary font-heading">Formulário de Validação de Dados</h3>
            <p class="text-xs text-slate-500">Corrija os dados se houver erros de leitura pela IA.</p>
          </div>
          <div class="text-xs text-slate-400 font-mono">
            Sessão: <%= @medical_request.conversation_id %>
          </div>
        </div>

        <div class="p-6 space-y-8">
          
          <!-- SEÇÃO 1: DADOS DO PACIENTE -->
          <div class="space-y-4">
            <h4 class="text-xs font-bold uppercase tracking-wider text-secondary border-b border-slate-100 pb-2">1. Dados Pessoais do Paciente</h4>
            
            <%= f.fields_for :patient do |p| %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                
                <!-- Nome -->
                <div class="flex flex-col">
                  <%= p.label :nome, "Nome do Paciente", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.text_field :nome, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-secondary text-sm shadow-sm transition-all" %>
                  <% if ai_patient[:nome].present? && ai_patient[:nome] != @medical_request.patient.nome %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 border border-amber-100 rounded px-2 py-0.5 mt-1 font-medium">Original IA: <%= ai_patient[:nome] %></span>
                  <% end %>
                </div>

                <!-- CPF -->
                <div class="flex flex-col">
                  <%= p.label :cpf, "CPF", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.text_field :cpf, disabled: is_readonly, placeholder: "000.000.000-00", class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-secondary text-sm shadow-sm transition-all" %>
                  <% if ai_patient[:cpf].present? && ai_patient[:cpf] != @medical_request.patient.cpf %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 border border-amber-100 rounded px-2 py-0.5 mt-1 font-medium">Original IA: <%= ai_patient[:cpf] %></span>
                  <% end %>
                </div>

                <!-- Data de Nascimento -->
                <div class="flex flex-col">
                  <%= p.label :data_nascimento, "Data de Nascimento", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.date_field :data_nascimento, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-secondary text-sm shadow-sm transition-all" %>
                  <% if ai_patient[:data_nascimento].present? && ai_patient[:data_nascimento] != @medical_request.patient.data_nascimento&.to_s %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 border border-amber-100 rounded px-2 py-0.5 mt-1 font-medium">Original IA: <%= ai_patient[:data_nascimento] %></span>
                  <% end %>
                </div>

                <!-- Sexo Biológico -->
                <div class="flex flex-col">
                  <%= p.label :sexo_biologico, "Sexo Biológico", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.select :sexo_biologico, [["Masculino", "M"], ["Feminino", "F"]], { include_blank: "Selecione..." }, { disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-secondary text-sm shadow-sm transition-all" } %>
                  <% if ai_patient[:sexo_biologico].present? && ai_patient[:sexo_biologico] != @medical_request.patient.sexo_biologico %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 border border-amber-100 rounded px-2 py-0.5 mt-1 font-medium">Original IA: <%= ai_patient[:sexo_biologico] %></span>
                  <% end %>
                </div>

                <!-- Telefone -->
                <div class="flex flex-col">
                  <%= p.label :telefone, "Telefone", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.text_field :telefone, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-secondary text-sm shadow-sm transition-all" %>
                  <% if ai_patient[:telefone].present? && ai_patient[:telefone] != @medical_request.patient.telefone %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 border border-amber-100 rounded px-2 py-0.5 mt-1 font-medium">Original IA: <%= ai_patient[:telefone] %></span>
                  <% end %>
                </div>

                <!-- ID Whatsapp / Link -->
                <div class="flex flex-col">
                  <%= p.label :id_whatsapp, "ID WhatsApp", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.text_field :id_whatsapp, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-secondary text-sm shadow-sm transition-all" %>
                  <% if ai_patient[:id_whatsapp].present? && ai_patient[:id_whatsapp] != @medical_request.patient.id_whatsapp %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 border border-amber-100 rounded px-2 py-0.5 mt-1 font-medium">Original IA: <%= ai_patient[:id_whatsapp] %></span>
                  <% end %>
                </div>
              </div>

              <!-- Endereço -->
              <h5 class="text-xs font-bold text-slate-400 mt-6 mb-2 uppercase tracking-wide">Endereço do Paciente</h5>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="flex flex-col md:col-span-2">
                  <%= p.label :logradouro, "Logradouro", class: "text-xs font-bold text-slate-600 mb-1" %>
                  <%= p.text_field :logradouro, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:logradouro].present? && ai_patient[:logradouro] != @medical_request.patient.logradouro %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:logradouro] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= p.label :numero, "Número", class: "text-xs font-bold text-slate-600 mb-1" %>
                  <%= p.text_field :numero, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:numero].present? && ai_patient[:numero] != @medical_request.patient.numero %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:numero] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= p.label :bairro, "Bairro", class: "text-xs font-bold text-slate-600 mb-1" %>
                  <%= p.text_field :bairro, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:bairro].present? && ai_patient[:bairro] != @medical_request.patient.bairro %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:bairro] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= p.label :cidade, "Cidade", class: "text-xs font-bold text-slate-600 mb-1" %>
                  <%= p.text_field :cidade, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:cidade].present? && ai_patient[:cidade] != @medical_request.patient.cidade %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:cidade] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= p.label :uf, "UF", class: "text-xs font-bold text-slate-600 mb-1" %>
                  <%= p.text_field :uf, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:uf].present? && ai_patient[:uf] != @medical_request.patient.uf %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:uf] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= p.label :cep, "CEP", class: "text-xs font-bold text-slate-600 mb-1" %>
                  <%= p.text_field :cep, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:cep].present? && ai_patient[:cep] != @medical_request.patient.cep %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:cep] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col md:col-span-2">
                  <%= p.label :complemento, "Complemento", class: "text-xs font-bold text-slate-600 mb-1" %>
                  <%= p.text_field :complemento, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:complemento].present? && ai_patient[:complemento] != @medical_request.patient.complemento %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:complemento] %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <!-- SEÇÃO 2: DADOS DO CONVÊNIO -->
          <div class="space-y-4">
            <h4 class="text-xs font-bold uppercase tracking-wider text-secondary border-b border-slate-100 pb-2">2. Convênio e Plano de Saúde</h4>
            
            <%= f.fields_for :patient do |p| %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex flex-col">
                  <%= p.label :convenio, "Nome do Convênio", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.text_field :convenio, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:convenio].present? && ai_patient[:convenio] != @medical_request.patient.convenio %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:convenio] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= p.label :plano_convenio, "Plano do Convênio", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.text_field :plano_convenio, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:plano_convenio].present? && ai_patient[:plano_convenio] != @medical_request.patient.plano_convenio %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:plano_convenio] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= p.label :numero_carteira, "Número da Carteirinha", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.text_field :numero_carteira, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:numero_carteira].present? && ai_patient[:numero_carteira] != @medical_request.patient.numero_carteira %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:numero_carteira] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= p.label :data_validade_carteira, "Validade da Carteirinha", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.date_field :data_validade_carteira, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:data_validade_carteira].present? && ai_patient[:data_validade_carteira] != @medical_request.patient.data_validade_carteira&.to_s %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:data_validade_carteira] %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <!-- SEÇÃO 3: MÉDICO SOLICITANTE -->
          <div class="space-y-4">
            <h4 class="text-xs font-bold uppercase tracking-wider text-secondary border-b border-slate-100 pb-2">3. Médico Solicitante</h4>
            
            <%= f.fields_for :requester do |r| %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex flex-col">
                  <%= r.label :nome, "Nome do Médico", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= r.text_field :nome, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_solicitante[:nome].present? && ai_solicitante[:nome] != @medical_request.requester.nome %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_solicitante[:nome] %></span>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= r.label :numero_conselho, "CRM / Número do Conselho", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= r.text_field :numero_conselho, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_solicitante[:numero_conselho].present? && ai_solicitante[:numero_conselho] != @medical_request.requester.numero_conselho %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_solicitante[:numero_conselho] %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <%= f.fields_for :patient do |p| %>
                <div class="flex flex-col">
                  <%= p.label :data_pedido_medico, "Data do Pedido Médico", class: "text-xs font-bold text-slate-700 mb-1" %>
                  <%= p.date_field :data_pedido_medico, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
                  <% if ai_patient[:data_pedido_medico].present? && ai_patient[:data_pedido_medico] != @medical_request.patient.data_pedido_medico&.to_s %>
                    <span class="text-[10px] text-amber-600 bg-amber-50 rounded px-2 mt-1">Original IA: <%= ai_patient[:data_pedido_medico] %></span>
                  <% end %>
                </div>
              <% end %>
              <div class="flex flex-col">
                <%= f.label :tipo, "Tipo de Pedido", class: "text-xs font-bold text-slate-700 mb-1" %>
                <%= f.text_field :tipo, disabled: is_readonly, class: "px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-secondary text-sm shadow-sm" %>
              </div>
            </div>
          </div>

          <!-- SEÇÃO 4: EXAMES SOLICITADOS -->
          <div class="space-y-4">
            <h4 class="text-xs font-bold uppercase tracking-wider text-secondary border-b border-slate-100 pb-2">4. Exames Solicitados</h4>
            
            <div class="space-y-3" id="exams-container">
              <%= f.fields_for :requested_exams do |exam_f| %>
                <div class="flex items-center gap-3 exam-item bg-slate-50 p-3 rounded-lg border border-slate-200 shadow-sm">
                  <div class="w-1/4">
                    <%= exam_f.label :codigo, "Código", class: "block text-[10px] font-bold text-slate-500 uppercase mb-1" %>
                    <%= exam_f.text_field :codigo, disabled: is_readonly, class: "w-full px-2.5 py-1.5 border border-slate-300 rounded-md focus:ring-1 focus:ring-secondary text-xs" %>
                  </div>
                  <div class="flex-grow">
                    <%= exam_f.label :descricao, "Descrição do Exame", class: "block text-[10px] font-bold text-slate-500 uppercase mb-1" %>
                    <%= exam_f.text_field :descricao, disabled: is_readonly, class: "w-full px-2.5 py-1.5 border border-slate-300 rounded-md focus:ring-1 focus:ring-secondary text-xs" %>
                  </div>
                  <% unless is_readonly %>
                    <div class="pt-4">
                      <%= exam_f.check_box :_destroy, class: "h-4 w-4 text-red-500 rounded border-slate-300 focus:ring-red-400 cursor-pointer" %>
                      <%= exam_f.label :_destroy, "Remover", class: "text-xs text-red-600 font-medium ml-1 cursor-pointer" %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <% unless is_readonly %>
              <button type="button" onclick="addExamField()" class="inline-flex items-center gap-1.5 px-3 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-bold rounded-lg border border-slate-200 cursor-pointer transition-colors shadow-sm">
                + Adicionar Exame
              </button>
            <% end %>
          </div>

        </div>

        <!-- Footer / Action Buttons -->
        <div class="p-6 border-t border-slate-100 bg-slate-50/80 flex items-center justify-between gap-4">
          <div class="text-xs text-slate-400">
            <% if @medical_request.pending? %>
              Clique em "Validar e Confirmar" para enviar os dados para a ZaikoHub.
            <% else %>
              Este registro já foi processado e enviado.
            <% end %>
          </div>
          
          <div class="flex items-center gap-3">
            <%= link_to "Cancelar", root_path, class: "px-4 py-2 text-slate-500 hover:text-slate-700 font-semibold text-sm transition-colors" %>
            <% if @medical_request.pending? %>
              <%= f.submit "Validar e Confirmar Dados", class: "px-5 py-2.5 bg-secondary hover:bg-secondary-hover text-white text-sm font-bold rounded-xl transition-all shadow-md shadow-secondary/20 cursor-pointer" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    
  </div>
</div>

<!-- Dynamic Template for Adding Exams (Rails style) -->
<template id="exam-template">
  <div class="flex items-center gap-3 exam-item bg-slate-50 p-3 rounded-lg border border-slate-200 shadow-sm mt-3 animate-fade-in">
    <div class="w-1/4">
      <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Código</label>
      <input type="text" name="medical_request[requested_exams_attributes][NEW_INDEX][codigo]" class="w-full px-2.5 py-1.5 border border-slate-300 rounded-md focus:ring-1 focus:ring-secondary text-xs">
    </div>
    <div class="flex-grow">
      <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Descrição do Exame</label>
      <input type="text" name="medical_request[requested_exams_attributes][NEW_INDEX][descricao]" class="w-full px-2.5 py-1.5 border border-slate-300 rounded-md focus:ring-1 focus:ring-secondary text-xs">
    </div>
    <div class="pt-4 flex items-center">
      <button type="button" onclick="this.closest('.exam-item').remove()" class="text-xs text-red-600 font-bold hover:text-red-800 transition-colors">Remover</button>
    </div>
  </div>
</template>

<script>
  // Dynamic Exam Add Script
  let examIndex = <%= @medical_request.requested_exams.count + 1 %>;
  function addExamField() {
    const container = document.getElementById('exams-container');
    const template = document.getElementById('exam-template').innerHTML;
    const html = template.replace(/NEW_INDEX/g, examIndex);
    container.insertAdjacentHTML('beforeend', html);
    examIndex++;
  }

  // Interactive Document Image Viewer Script (Zoom / Pan / Draw)
  let currentDoc = '';
  let zoomScale = 1.6;
  let zoomX = 0;
  let zoomY = 0;
  let isDragging = false;
  let startX = 0;
  let startY = 0;

  // Draw State
  let drawMode = false;
  let isDrawing = false;
  let currentColor = '#ff0000'; // Default red
  let context = null;

  const zoomBox = document.getElementById('image-zoom-box');
  const canvas = document.getElementById('drawing-canvas');
  const drawToolbar = document.getElementById('draw-toolbar');
  
  if (canvas) {
    context = canvas.getContext('2d');
    
    // Resize canvas to match its container exactly
    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
      context.lineWidth = 3;
      context.lineCap = 'round';
      context.lineJoin = 'round';
    }
    window.addEventListener('resize', resizeCanvas);
    setTimeout(resizeCanvas, 100);
  }

  // Select between document tabs
  function selectImage(docType) {
    // Hide all image tags
    ['pedido_medico', 'documento', 'carteira_convenio'].forEach(type => {
      const img = document.getElementById('img-' + type);
      const tab = document.getElementById('tab-' + type);
      if (img) img.classList.add('hidden');
      if (tab) {
        tab.classList.remove('bg-primary', 'text-white', 'border-primary');
        tab.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
      }
    });

    // Show selected
    currentDoc = docType;
    const activeImg = document.getElementById('img-' + docType);
    const activeTab = document.getElementById('tab-' + docType);
    
    if (activeImg) {
      activeImg.classList.remove('hidden');
      
      // If PDF, disable drawing mode entirely
      if (activeImg.tagName.toLowerCase() === 'iframe') {
        drawToolbar.classList.add('hidden');
        if (drawMode) toggleDrawMode(); // turn it off
      } else {
        drawToolbar.classList.remove('hidden');
      }
    }

    if (activeTab) {
      activeTab.classList.add('bg-primary', 'text-white', 'border-primary');
      activeTab.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
    }

    // Reset zoom state on document change
    resetViewer();
  }

  // Set Zoom
  function updateTransform() {
    zoomBox.style.transform = `scale(${zoomScale}) translate(${zoomX}px, ${zoomY}px)`;
  }

  function adjustZoom(amount) {
    zoomScale += amount;
    if (zoomScale < 0.5) zoomScale = 0.5;
    if (zoomScale > 4) zoomScale = 4;
    updateTransform();
  }

  function resetViewer() {
    zoomScale = 1.6;
    zoomX = 0;
    zoomY = 0;
    updateTransform();
  }

  // -------------------------
  // DRAWING CONTROLS
  // -------------------------
  function toggleDrawMode() {
    drawMode = !drawMode;
    const btnDraw = document.getElementById('btn-draw');
    
    if (drawMode) {
      btnDraw.classList.add('bg-secondary', 'ring-2', 'ring-offset-2', 'ring-offset-slate-800');
      canvas.classList.remove('pointer-events-none', 'hidden');
      canvas.style.cursor = 'crosshair';
      zoomBox.parentElement.style.cursor = 'crosshair';
    } else {
      btnDraw.classList.remove('bg-secondary', 'ring-2', 'ring-offset-2', 'ring-offset-slate-800');
      canvas.classList.add('pointer-events-none');
      zoomBox.parentElement.style.cursor = 'default';
    }
  }

  function setDrawColor(color) {
    currentColor = color;
    if (!drawMode) toggleDrawMode(); // Auto-enable if color picked
  }

  function clearDraw() {
    if (context && canvas) {
      context.clearRect(0, 0, canvas.width, canvas.height);
    }
  }

  // Canvas Mouse Events
  if (canvas) {
    canvas.addEventListener('mousedown', (e) => {
      if (!drawMode) return;
      isDrawing = true;
      const rect = canvas.getBoundingClientRect();
      
      // Quando redimensionamos/damos zoom, o CSS do elemento pai manipula o scale.
      // Precisamos normalizar a coordenada X/Y para o canvas ignorando a escala CSS, pois
      // o mouseEvent.clientX/Y está relativo à viewport e o rect à tela escalada.
      // E precisamos desenhar na resolução lógica do Canvas
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;

      const x = (e.clientX - rect.left) * scaleX;
      const y = (e.clientY - rect.top) * scaleY;
      
      context.beginPath();
      context.moveTo(x, y);
      e.stopPropagation(); // prevent pan
    });

    canvas.addEventListener('mousemove', (e) => {
      if (!drawMode || !isDrawing) return;
      const rect = canvas.getBoundingClientRect();
      
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;

      const x = (e.clientX - rect.left) * scaleX;
      const y = (e.clientY - rect.top) * scaleY;
      
      context.strokeStyle = currentColor;
      context.lineTo(x, y);
      context.stroke();
      e.stopPropagation();
    });

    canvas.addEventListener('mouseup', () => { isDrawing = false; });
    canvas.addEventListener('mouseleave', () => { isDrawing = false; });
  }

  // -------------------------
  // PANNING CONTROLS
  // -------------------------
  zoomBox.parentElement.addEventListener('mousedown', (e) => {
    if (drawMode) return; // don't pan if drawing
    
    // Ignore if clicking on iframe
    if (e.target.tagName.toLowerCase() === 'iframe') return;

    isDragging = true;
    startX = e.clientX - zoomX;
    startY = e.clientY - zoomY;
    zoomBox.classList.remove('transition-all'); // disable transition during drag
  });

  document.addEventListener('mousemove', (e) => {
    if (!isDragging || drawMode) return;
    zoomX = e.clientX - startX;
    zoomY = e.clientY - startY;
    updateTransform();
  });

  document.addEventListener('mouseup', () => {
    if (isDragging) {
      isDragging = false;
      zoomBox.classList.add('transition-all'); // re-enable transition
    }
  });

  // Initialize with 'pedido_medico' selected by default
  document.addEventListener('DOMContentLoaded', () => {
    selectImage('pedido_medico');
  });
</script>
