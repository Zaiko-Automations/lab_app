<div class="flex-grow flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-gradient-to-tr from-slate-100 via-slate-50 to-teal-50/50">
  <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-2xl shadow-xl border border-slate-100">
    <div class="text-center">
      <div class="mx-auto h-12 w-12 rounded-xl bg-primary flex items-center justify-center font-bold text-white shadow-md text-xl font-heading">
        Z
      </div>
      <h2 class="mt-6 text-3xl font-extrabold text-primary tracking-tight font-heading">Acesse o Zaiko Image</h2>
      <p class="mt-2 text-sm text-slate-500">
        Digite suas credenciais de atendente
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-6" }) do |f| %>
      <% if flash[:alert] %>
        <!-- Handled in layout, but fallback if needed -->
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :email, "E-mail Corporativo", class: "block text-sm font-semibold text-slate-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "appearance-none relative block w-full px-3 py-2.5 border border-slate-300 placeholder-slate-400 text-slate-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary sm:text-sm transition-all shadow-sm" %>
        </div>

        <div>
          <%= f.label :password, "Senha de Acesso", class: "block text-sm font-semibold text-slate-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password", required: true, class: "appearance-none relative block w-full px-3 py-2.5 border border-slate-300 placeholder-slate-400 text-slate-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary sm:text-sm transition-all shadow-sm" %>
        </div>
      </div>

      <div class="flex items-center justify-between">
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "h-4 w-4 text-secondary focus:ring-secondary border-slate-300 rounded cursor-pointer" %>
            <%= f.label :remember_me, "Lembrar-me neste computador", class: "ml-2 block text-sm text-slate-600 cursor-pointer" %>
          </div>
        <% end %>
      </div>

      <div>
        <%= f.submit "Entrar no Painel", class: "group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-primary hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary transition-all cursor-pointer shadow-md shadow-primary/20" %>
      </div>
    <% end %>
  </div>
</div>
